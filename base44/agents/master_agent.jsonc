      "allowed_operations": [
        "read"
      ]
    },
    {
      "entity_name": "CustomerProfile",
      "allowed_operations": [
        "read",
        "create",
        "update"
      ]
    },
    {
      "entity_name": "SalesInteraction",
      "allowed_operations": [
        "read",
        "create"
      ]
    },
    {
      "entity_name": "Notification",
      "allowed_operations": [
        "create",
        "read"
      ]
    },
    {
